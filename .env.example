# Postgres credentials (used by docker-compose.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sendit_db

# In Docker: use the service name "postgres" as host, port 5432
# Local dev (docker-compose.yml): use localhost:5433
DATABASE_URL="postgresql://postgres:changeme@postgres:5432/sendit_db"

JWT_ACCESS_SECRET=""
JWT_ACCESS_EXPIRES_IN="15m"
JWT_PENDING_SECRET=""
JWT_PENDING_EXPIRES_IN="5m"

TOTP_ENCRYPTION_KEY=""   # 64 hex chars = 32 bytes

ALLOWED_ORIGINS="http://localhost:5173"

NOVA_POST_BASE_URL="https://api-stage.novapost.pl/v.1.0"

# DEV ONLY: minutes until scheduled switch activates (default 1440 = next midnight)
# Set to 1 for quick testing
SWITCH_DELAY_MINUTES=1440
